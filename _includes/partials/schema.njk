{% set pageTitle = title or metadata.title %}
{% set pageDesc = description or excerpt or metadata.description %}
{% set pageImage = image or metadata.image %}
{% set isAcademic = ("/archives/" in page.url) or (metadata.title == "Journal New Polis") %}
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "NGO",
    "@id": "https://thewhitestonefoundation.org",
    "name": "The Whitestone Foundation",
    "url": "https://thewhitestonefoundation.org",
    "logo": "{{ metadata.url }}{{ metadata.favicon }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Boulder",
      "addressRegion": "CO",
      "addressCountry": "US"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "{{ metadata.url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ metadata.url }}/search/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
]
</script>

{% if page.url == "/" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "{{ metadata.title }}",
  "description": "{{ metadata.description }}",
  "url": "{{ metadata.url }}",
  "publisher": {
    "@id": "https://thewhitestonefoundation.org"
  }
}
</script>
{% else %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ 'ScholarlyArticle' if isAcademic else 'BlogPosting' }}",
  "headline": "{{ pageTitle }}",
  "description": "{{ pageDesc | truncate(160) }}",
  "image": "{{ pageImage }}",
  "datePublished": "{{ date | isoDate if date else metadata.buildTime }}",
  "author": {
    "@type": "Person",
    "name": "{{ author or metadata.author.name }}",
    "url": "{{ metadata.url }}/authors/{{ author | slugify }}/"
  },
  "publisher": {
    "@id": "https://thewhitestonefoundation.org"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ metadata.url }}{{ page.url }}"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ metadata.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ pageTitle }}",
      "item": "{{ metadata.url }}{{ page.url }}"
    }
  ]
}
</script>
{% endif %}